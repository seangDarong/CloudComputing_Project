<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Students — EduCloud</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>

<nav class="navbar">
  <span class="nav-logo">🎓 EduCloud</span>
  <div class="nav-links">
    <a href="/">Register</a>
    <a href="/students" class="active">View Students</a>
  </div>
</nav>

<div class="page-header">
  <h1>Registered Students</h1>
  <p>All students currently in the system</p>
</div>

<div class="container wide">

  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-number"><%= students.length %></div>
      <div class="stat-label">Total Students</div>
    </div>
  </div>

  <div class="card">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h2 style="font-size:18px; color:#1a237e;">Student List</h2>
      <a href="/" class="btn btn-secondary">+ Register New</a>
    </div>

    <% if (students.length === 0) { %>
      <div class="empty-state">
        <div class="icon">📭</div>
        <p>No students registered yet.</p>
        <a href="/" class="btn btn-primary" style="width:auto;">Register First Student</a>
      </div>

    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Photo</th>
            <th>Student ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Registered</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(student => { %>
          <tr>
            <td>
              <% if (student.photo_url) { %>
                <img src="<%= student.photo_url %>" class="student-photo" alt="photo"/>
              <% } else { %>
                <span class="photo-placeholder">👤</span>
              <% } %>
            </td>
            <td><strong><%= student.student_id %></strong></td>
            <td><%= student.name %></td>
            <td><%= student.email %></td>
            <td><span class="badge"><%= student.course %></span></td>
            <td style="color:#888; font-size:13px;">
              <%= new Date(student.registered_at).toLocaleDateString('en-GB', {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
              }) %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>
</div>

<div class="footer">
  EduCloud &copy; 2024 — Hosted on AWS EC2 + RDS + S3
</div>

</body>
</html>
```

